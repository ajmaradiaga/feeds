    <title>404 error while calling SAP Build Work Zone(Launchpad) Notification API in BAS</title>
    <updated>2024-04-16T15:28:00.802000+02:00</updated>
    <author>
      <name>Vikas-Kumar</name>
      <uri>https://community.sap.com/t5/user/viewprofilepage/user-id/1439242</uri>
